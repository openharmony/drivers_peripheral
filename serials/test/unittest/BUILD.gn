import("//build/ohos.gni")
import("//build/test.gni")

module_output_path = "drivers_peripheral_serial/drivers_peripheral_serial"

ohos_unittest("hdf_serials_unittest") {
  module_out_path = module_output_path
  sources = [ "hdf_serials_test.cpp" ]

  include_dirs = [ "../../include" ]

  external_deps = [
    "c_utils:utils",
    "drivers_interface_serial:libserials_proxy_1.0",
    "googletest:gtest",
    "hdf_core:libhdf_utils",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]

  cflags = [
    "-Wall",
    "-Wextra",
    "-Werror",
    "-fsigned-char",
    "-fno-common",
    "-fno-strict-aliasing",
  ]

  subsystem_name = "hdf"
  part_name = "drivers_peripheral_serial"
}

group("serials_unittest") {
  testonly = true
  deps = [ ":hdf_serials_unittest" ]
}