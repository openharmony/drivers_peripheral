import("//build/config/features.gni")
import("//build/test.gni")
import("//drivers/peripheral/usb/usb.gni")
import("./../fuzztest.gni")
module_output_path = "drivers_peripheral_usb/drivers_peripheral_usb"

ohos_fuzztest("UsbGetNonRootHubsFuzzTest") {
  module_out_path = module_output_path

  fuzz_config_file = "../usbgetnonroothubs_fuzzer"

  sources = [
    "usbgetnonroothubs_fuzzer.cpp",
  ]

  include_dirs = [
    "../usbgetnonroothubs_fuzzer",
  ]

  deps = [
    "../../../ddk_service/usb_service:usb_ddk_target",
  ]

  external_deps = [
    "c_utils:utils",
    "drivers_interface_usb:libusb_ddk_proxy_1.2",
    "hdf_core:libhdi_base",
    "hdf_core:libhdf_utils",
    "hilog:libhilog",
  ]
}

group("fuzztest") {
  testonly = true
  deps = []
  deps += [ ":UsbGetNonRootHubsFuzzTest" ]
}
