import("//build/test.gni")
import("./../../../usb.gni")

module_output_path = "drivers_peripheral_usb/drivers_peripheral_usb"

config("module_private_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "include",
    "./../../../libusb_adapter/include",
    "./../../../hdi_service/include",
    "./../../../ddk/host/include",
    "${usb_driver_path}/utils/include",
  ]
}

ohos_unittest("libusb_adapter_test") {
  sources = [
    "src/libusb_adapter_test.cpp",
  ]

  configs = [ ":module_private_config" ]

  deps = [
    "${usb_driver_path}/libusb_adapter:libusb_adapter",
    "${usb_driver_path}/hdi_service:libusb_interface_service_1.2",
  ]

  external_deps = [
    "c_utils:utils",
    "drivers_interface_usb:libusb_proxy_1.0",
    "googletest:gtest_main",
    "hdf_core:libhdf_utils",
    "hilog:libhilog",
    "ipc:ipc_single",
    "samgr:samgr_proxy",
  ]
  module_out_path = module_output_path
}

group("libusb_adapter_group") {
  testonly = true
  deps = [ ":libusb_adapter_test" ]
}
