import("//build/config/features.gni")
import("//build/test.gni")
import("../../../codec.gni")
module_output_path = "drivers_peripheral_codec/drivers_peripheral_codec"

# End-to-End encode/decode fuzzer
ohos_fuzztest("ZCodecEnDecodeFuzzTest") {
  testonly = true
  module_out_path = module_output_path

  include_dirs = [
    "../../demo/zcodec/tester",
    "../../../utils/include"
  ]
  external_deps = [
    "c_utils:utils",
    "drivers_interface_codec:video_parcel_headers",
    "drivers_interface_codec:zcodec_idl_headers",
    "drivers_interface_codec:libzcodec_proxy_1.0",
    "hdf_core:libhdi",
    "hdf_core:libhdf_utils",
    "graphic_surface:buffer_handle",
    "graphic_surface:surface",
    "hilog:libhilog",
    "ipc:ipc_single",
  ]

  deps = [
    "../../demo/zcodec/tester:libzencoder_tester",
    "../../demo/zcodec/tester:libzdecoder_tester"
  ]
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]
  sources = [ "zcodec_endecode_fuzzer.cpp" ]
}

group("zcodec_hdi_fuzzer") {
  testonly = true
  deps = []
  if (!drivers_peripheral_codec_feature_support_omx_extend_test) {
    deps += [
      ":ZCodecEnDecodeFuzzTest"
    ]
  }
}