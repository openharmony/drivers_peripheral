  install_images = [ "vendor" ]
  part_name = "video"

  resource_config_file =
      "../resources/ohos_test.xml"
}

group("zcodec_idl_1.0_test") {
  testonly = true
  deps = [
    ":zcodec_idl_buffer_unit_test",
    ":zcodec_enc_idl_unit_test",
    ":zcodec_dec_idl_unit_test",
  ]
}