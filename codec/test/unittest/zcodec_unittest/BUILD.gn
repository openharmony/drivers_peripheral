ohos_unittest("zcodec_idl_buffer_unit_test") {
  testonly = true
  module_out_path = "drivers_peripheral_codec/drivers_peripheral_codec"
  sources = [
    "zcodec_idl_buffer_unit_test.cpp",
  ]

  deps = [
    "../../demo/zcodec/tester:libzencoder_tester",
    "../../demo/zcodec/tester:libzdecoder_tester"
  ]

  external_deps = [
      "c_utils:utils",
      "drivers_interface_codec:video_parcel_headers",
      "drivers_interface_codec:zcodec_idl_headers",
      "hdf_core:libhdi",
      "hdf_core:libhdf_utils",
