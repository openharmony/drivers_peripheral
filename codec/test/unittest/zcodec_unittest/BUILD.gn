import("//build/ohos.gni")
import("//build/test.gni")

ohos_unittest("zcodec_enc_idl_unit_test") {
  testonly = true
  module_out_path = "drivers_peripheral_codec/drivers_peripheral_codec"
  sources = [
    "zcodec_enc_idl_test.cpp",
    "zcodec_enc_idl_edge_test.cpp",
  ]
  external_deps = [
      "c_utils:utils",
      "drivers_interface_codec:video_parcel_headers",
      "drivers_interface_codec:zcodec_idl_headers",
      "drivers_interface_codec:libzcodec_proxy_1.0",
      "hdf_core:libhdi",
      "hdf_core:libhdf_utils",
      "graphic_surface:buffer_handle",
      "graphic_surface:surface",
      "hilog:libhilog",
      "ipc:ipc_single",
  ]
  include_dirs = [
      "../../../utils/include",
  ]
  install_images = [ "vendor" ]
  part_name = "video"
}

